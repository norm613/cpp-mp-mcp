# Copy this to .env and fill in values. All creds are instance-level (shared
# across users of the same MP tenant). .env is gitignored — never committed.

# === Ministry Platform credentials (shared instance-level) ===

# Production OAuth client
MP_BASE_URL=https://mp.archomaha.org/ministryplatformapi/
MP_OAUTH_TOKEN_URL=https://mp.archomaha.org/ministryplatformapi/oauth/connect/token
MP_CLIENT_ID=Claude@Rest
MP_CLIENT_SECRET=
MP_SCOPE=http://www.thinkministry.com/dataplatform/scopes/all

# Sandbox (optional — uncomment if you want sandbox tools registered)
# MP_SANDBOX_BASE_URL=https://mpsandbox.archomaha.org/ministryplatformapi/
# MP_SANDBOX_OAUTH_TOKEN_URL=https://mpsandbox.archomaha.org/ministryplatformapi/oauth/connect/token
# MP_SANDBOX_CLIENT_ID=Claude@RestInSandbox
# MP_SANDBOX_CLIENT_SECRET=

# === Path to local MPNext install (MPHelper source) ===
# Default assumes MPNext is at %USERPROFILE%\code\MPNext (canonical location).
# Override only if you installed MPNext elsewhere.
# MPNEXT_PATH=C:\Users\YOU\code\MPNext
